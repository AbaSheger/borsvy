# Backend local development example.
# Copy to backend/.env and fill only the providers you want to use.

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:3001

# Auth
JWT_SECRET=replace-with-a-long-random-base64-or-secret-string

# Market data
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=
TWELVEDATA_API_URL=https://api.twelvedata.com

# News
NEWSDATA_API_KEY=
NEWSDATA_API_URL=https://newsdata.io/api/1
RAPIDAPI_API_KEY=
RAPIDAPI_API_HOST=yahoo-finance166.p.rapidapi.com

# AI summaries
GROQ_API_KEY=

# Optional email/Stripe placeholders
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Optional PostgreSQL override. Leave unset to use the default H2 file DB.
# DATABASE_URL=jdbc:postgresql://localhost:5432/borsvy
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# DB_USERNAME=borsvy
# DB_PASSWORD=borsvy
# JPA_DDL_AUTO=validate
# FLYWAY_ENABLED=true
