# Auto detect text files and perform LF normalization
* text=auto

# Documents
*.md text diff=markdown
*.txt text
*.json text
*.yml text
*.yaml text
*.xml text
*.html text
*.css text
*.js text
*.ts text
*.jsx text
*.tsx text

# Source code
*.java text
*.properties text
*.gradle text
*.kt text
*.kts text

# Shell scripts
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.eot binary
*.ttf binary
*.woff binary
*.woff2 binary
*.jar binary
*.class binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# IDE
.vscode/* text
.idea/* text
*.iml text
*.iws text
*.ipr text

# Build
target/ binary
dist/ binary
build/ binary
node_modules/ binary 